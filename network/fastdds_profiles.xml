<?xml version="1.0" encoding="UTF-8"?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <!--
        Fast DDS Profile for WSL2 + Windows Isaac Sim Communication
        
        Binds ROS 2 DDS traffic to loopback (127.0.0.1) only.
        Works with WSL2 mirrored networking for cross-OS discovery.
        
        Compatible with Fast DDS 2.6.x (ROS 2 Humble).
        
        Usage:
          Set FASTRTPS_DEFAULT_PROFILES_FILE to point to this file.
          Set ROS_DOMAIN_ID=10 on all sides.
    -->

    <transport_descriptors>
        <transport_descriptor>
            <transport_id>loopback_udp</transport_id>
            <type>UDPv4</type>
            <interfaceWhiteList>
                <address>127.0.0.1</address>
            </interfaceWhiteList>
            <TTL>1</TTL>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="default_participant" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>loopback_udp</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>

            <builtin>
                <initialPeersList>
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
                <metatrafficUnicastLocatorList>
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                        </udpv4>
                    </locator>
                </metatrafficUnicastLocatorList>
            </builtin>

            <defaultUnicastLocatorList>
                <locator>
                    <udpv4>
                        <address>127.0.0.1</address>
                    </udpv4>
                </locator>
            </defaultUnicastLocatorList>

            <sendSocketBufferSize>65536</sendSocketBufferSize>
            <listenSocketBufferSize>65536</listenSocketBufferSize>
        </rtps>
    </participant>
</profiles>
