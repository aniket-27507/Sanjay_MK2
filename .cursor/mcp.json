{
  "mcpServers": {
    "isaac-sim": {
      "type": "stdio",
      "command": ".venv/Scripts/python.exe",
      "args": ["-m", "isaac_mcp.server", "--config", "config/mcp_server.yaml"],
      "cwd": "IsaacMCP",
      "env": {
        "PYTHONPATH": ".",
        "ISAAC_MCP_LOCAL_LOG_PATH": "~/.nvidia-omniverse/logs/Kit"
      }
    }
  }
}
