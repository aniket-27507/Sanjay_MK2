# OS metadata
.DS_Store
._*

# Python
venv/
.venv/
**/__pycache__/
*.pyc
*.pyo

# IDE / tools
.claude/
.cursor/
.mcp.json
.pytest_cache/

# Build / dist
.dist/

# Temp / sync
.tmp.driveupload/
.tmp.drivedownload/

# Runtime artifacts
*.log
simulation/logs/*.json
test_report_*.txt
test_results*.txt
FINAL_TEST_REPORT.md

# Local training/runtime outputs
.ultralytics/
datasets/
weights/
runs/
reports/day1/*.json
reports/day1/*.txt
reports/day1/*.log
!reports/day1/STATUS.md

# Stray model weights at any depth (police_full_v2.pt, thermal_police_v1.pt,
# auto-downloaded yolo11s.pt, etc.) -- model weights should never be committed
*.pt
*.onnx
*.engine

# Demo media (source video typically large; samples/ is the canonical drop dir)
samples/*.mp4
samples/*.mov
samples/*.avi
# Demo viewer outputs (auto-named sanjay_demo_<mode>_<timestamp>.mp4)
sanjay_demo_*.mp4
# Operator-workflow demo audit runs (per-incident clips, decisions, evidence audit)
audit_runs/

# Binary documents
*.docx
